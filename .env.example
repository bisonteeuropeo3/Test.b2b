# Environment Variables Example
# Copia questo file in .env.local e inserisci i tuoi valori

# Supabase Configuration - Vercel Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://djqtrggbnomhpjfkxjoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTA: Per produzione su Vercel, imposta queste variabili in:
# Vercel Dashboard → Project Settings → Environment Variables
